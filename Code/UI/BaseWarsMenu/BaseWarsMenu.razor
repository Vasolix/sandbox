@using Sandbox;
@using Sandbox.UI;
@namespace Sandbox
@inherits Panel
@attribute [SpawnMenuHost.SpawnMenuMode]
@attribute [Icon( "💰" )]
@attribute [Title( "#spawnmenu.mode.basewars" )]
@attribute [Order( -90 )]

<root>
	<div class="basewars-card">
		<header>
			<div class="profile-section">
				<div class="avatar">
					<img src="avatar:@Me?.SteamId" />
				</div>
				<div class="info">
					<div class="pseudo">@Pseudo</div>
					<div class="level-container">
						<div class="level-badge">#basewars.menu.level @Level</div>
						<div class="xp-bar">
							<div class="fill" style="width: @( ( (float)Experience / ExperienceRequired ) * 100 )%"></div>
							<div class="text">@Experience / @ExperienceRequired #basewars.menu.xp</div>
						</div>
					</div>
				</div>
			</div>
			<div class="money">
				$@Money.ToString( "N0" )
			</div>
		</header>

		<div class="main-content">
			<div class="left-panel">
				<div class="section-title">#basewars.menu.printers</div>
				<div class="printer-list">
					@if ( !OwnedPrinters.Any() )
					{
						<div class="empty-msg">#basewars.menu.no_printers</div>
					}
					else
					{
						@foreach ( var printer in OwnedPrinters )
						{
							<div class="printer-row">
								<div class="icon" style="background-color: @printer.Definition.ColorCss">@printer.Definition.Icon</div>
								<div class="details">
									<div class="name">@printer.Definition.Name</div>
									<div class="stored">#basewars.menu.stored: $@printer.Printer.StoredMoney</div>
									<div class="meta">$@printer.Definition.PrintAmount / @printer.Definition.PrintInterval.ToString( "0.#" )s | @printer.Definition.Health.ToString( "0" ) HP</div>
								</div>
							</div>
						}
					}
				</div>
			</div>

			<div class="right-panel">
				<div class="description">
					#basewars.menu.description
				</div>

				<div class="actions">
					<div class="shop-grid">
						@foreach ( var printerDefinition in PrinterDefinitions )
						{
							<div class="shop-card">
								<div class="shop-head">
									<div class="shop-icon" style="background-color: @printerDefinition.ColorCss">@printerDefinition.Icon</div>
									<div class="shop-title">
										<div class="name">@printerDefinition.Name</div>
										<div class="cost">$@printerDefinition.Cost.ToString( "N0" )</div>
									</div>
								</div>
								<div class="stats-grid">
									<div>
										<label>#basewars.menu.production</label>
										<span>$@printerDefinition.PrintAmount</span>
									</div>
									<div>
										<label>#basewars.menu.interval</label>
										<span>@printerDefinition.PrintInterval.ToString( "0.#" )s</span>
									</div>
									<div>
										<label>#basewars.menu.health</label>
										<span>@printerDefinition.Health.ToString( "0" ) HP</span>
									</div>
								</div>
								<button class="primary" onclick=@( () => BuyPrinter( printerDefinition.Id ) )>
									<div class="label">#basewars.menu.buy_printer</div>
								</button>
							</div>
						}
					</div>
				</div>
			</div>
		</div>

		<footer>
			<div class="hint">#basewars.menu.hint</div>
		</footer>
	</div>
</root>

@code
{
	private sealed class PrinterDefinition
	{
		public string Id { get; init; }
		public string Name { get; init; }
		public string Icon { get; init; }
		public int Cost { get; init; }
		public int PrintAmount { get; init; }
		public float PrintInterval { get; init; }
		public float Health { get; init; }
		public Color Tint { get; init; }
		public string ColorCss { get; init; }
	}

	private sealed class OwnedPrinterView
	{
		public BaseWarsPrinter Printer { get; init; }
		public PrinterDefinition Definition { get; init; }
	}

	static readonly IReadOnlyList<PrinterDefinition> PrinterDefinitions = new List<PrinterDefinition>
	{
		new()
		{
			Id = "starter",
			Name = "Starter Printer",
			Icon = "1",
			Cost = 250,
			PrintAmount = 25,
			PrintInterval = 5f,
			Health = 100f,
			Tint = new Color( 0.2f, 0.85f, 0.45f ),
			ColorCss = "#22c55e"
		},
		new()
		{
			Id = "industrial",
			Name = "Industrial Printer",
			Icon = "2",
			Cost = 750,
			PrintAmount = 60,
			PrintInterval = 4f,
			Health = 140f,
			Tint = new Color( 0.95f, 0.62f, 0.16f ),
			ColorCss = "#f59e0b"
		},
		new()
		{
			Id = "quantum",
			Name = "Quantum Printer",
			Icon = "3",
			Cost = 1800,
			PrintAmount = 150,
			PrintInterval = 3f,
			Health = 180f,
			Tint = new Color( 0.56f, 0.42f, 0.95f ),
			ColorCss = "#8b5cf6"
		}
	};

	PlayerData Me => Player.FindLocalPlayer()?.PlayerData;
	int Money => Me?.Money ?? 0;
	int Level => Me?.Level ?? 1;
	int Experience => Me?.Experience ?? 0;
	int ExperienceRequired => Me?.ExperienceRequired ?? 1000;
	string Pseudo => Me?.DisplayName ?? "Player";

	IEnumerable<BaseWarsPrinter> MyPrinters => Game.ActiveScene.GetAll<BaseWarsPrinter>().Where( x => x.OwnerData == Me );
	IReadOnlyList<OwnedPrinterView> OwnedPrinters => MyPrinters.Select( x => new OwnedPrinterView { Printer = x, Definition = GetPrinterDefinition( x.PrinterTypeId ) } ).ToList();

	[Rpc.Host]
	private static void BuyPrinter( string printerTypeId )
	{
		var player = Player.FindForConnection( Rpc.Caller );
		if ( !player.IsValid() || !player.PlayerData.IsValid() ) return;

		var definition = GetPrinterDefinition( printerTypeId );
		if ( !player.PlayerData.TrySpendMoney( definition.Cost ) )
		{
			Notices.SendNotice( player.Network.Owner, "payments", Color.Red, $"Pas assez d'argent. Il faut ${definition.Cost}.", 3 );
			return;
		}

		var eyes = player.EyeTransform;
		var trace = Game.SceneTrace.Ray( eyes.Position, eyes.Position + eyes.Forward * 2048 )
			.IgnoreGameObject( player.GameObject )
			.WithoutTags( "player" )
			.Run();

		var up = trace.Normal;
		var backward = -eyes.Forward;
		var right = Vector3.Cross( up, backward ).Normal;
		var forward = Vector3.Cross( right, up ).Normal;
		var rotation = Rotation.LookAt( forward, up );
		var transform = new Transform( trace.EndPosition + up * 24f, rotation );

		var go = new GameObject( false, definition.Name );
		go.Tags.Add( "removable" );
		go.WorldTransform = transform;

		var renderer = go.AddComponent<ModelRenderer>();
		renderer.Model = Model.Load( "models/dev/box.vmdl" );
		renderer.MaterialOverride = Material.Load( "materials/dev/reflectivity_30.vmat" );
		renderer.Tint = definition.Tint;

		var collider = go.AddComponent<BoxCollider>();
		collider.Scale = new Vector3( 36f, 28f, 20f );
		collider.Center = Vector3.Zero;

		go.AddComponent<Rigidbody>();

		var printer = go.AddComponent<BaseWarsPrinter>();
		printer.OwnerData = player.PlayerData;
		printer.PrinterTypeId = definition.Id;
		printer.PrintAmount = definition.PrintAmount;
		printer.PrintInterval = definition.PrintInterval;
		printer.Health = definition.Health;

		Ownable.Set( go, player.Network.Owner );
		CreatePrinterDisplay( go );
		go.NetworkSpawn( true, null );

		Notices.SendNotice( player.Network.Owner, "shopping_cart", Color.Green, $"{definition.Name} achete pour ${definition.Cost}.", 3 );
	}

	private static void CreatePrinterDisplay( GameObject printer )
	{
		var screen = new GameObject( printer, false, "Printer Screen" );
		screen.LocalPosition = new Vector3( 18.5f, 0f, 10f );
		screen.LocalRotation = Rotation.FromYaw( 90f );
		screen.LocalScale = new Vector3( 0.28f, 0.18f, 1f );

		var panel = screen.AddComponent<ModelRenderer>();
		panel.Model = Model.Load( "models/dev/plane_blend.vmdl" );
		panel.MaterialOverride = Material.Load( "materials/dev/reflectivity_30.vmat" );
		panel.Tint = Color.Black;

		var text = new GameObject( screen, false, "Printer Screen Text" );
		text.LocalPosition = new Vector3( 0f, 0f, 1f );

		var textRenderer = text.AddComponent<TextRenderer>();
		textRenderer.Text = "$0";
		textRenderer.HorizontalAlignment = TextRenderer.HAlignment.Center;
		textRenderer.VerticalAlignment = TextRenderer.VAlignment.Center;
		textRenderer.FontFamily = "Poppins";
		textRenderer.FontSize = 42f;
		textRenderer.FontWeight = 800;
		textRenderer.Scale = 0.25f;
		textRenderer.Color = Color.Green;
	}

	protected override int BuildHash()
	{
		return HashCode.Combine( Money, Experience, Level, MyPrinters.Count(), MyPrinters.Sum( x => x.StoredMoney ) );
	}

	private static PrinterDefinition GetPrinterDefinition( string printerTypeId )
	{
		return PrinterDefinitions.FirstOrDefault( x => x.Id == printerTypeId ) ?? PrinterDefinitions[0];
	}
}
